# Database
POSTGRES_USER=annotateflow
POSTGRES_PASSWORD=annotateflow_secret
POSTGRES_DB=annotateflow
DATABASE_URL=postgresql+asyncpg://annotateflow:annotateflow_secret@localhost:5432/annotateflow

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=annotateflow-uploads
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
